# SSHPanel — environment template
#
# 1. Copy this file:    cp .env.example .env
# 2. Generate a key:    openssl rand -hex 32
# 3. Paste it below.    DO NOT commit .env to git.

# Required — encrypts SSH passwords and sudo passwords stored in the DB.
# If you lose this key, all saved credentials become unrecoverable.
SECRET_KEY=

# Optional — public port for the web UI. Default 8080.
SSHPANEL_PORT=8080

# Optional — server timezone (affects log timestamps in containers).
TZ=UTC
